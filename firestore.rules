rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for projects collection
    match /projects/{projectId} {
      // Allow read if the user is logged in and owns the project
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow create if the user is logged in and the new project is assigned to their own uid
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Allow update if the user is logged in, owns the project, and isn't trying to change ownership
      allow update: if request.auth != null 
                    && request.auth.uid == resource.data.userId
                    && request.auth.uid == request.resource.data.userId;
                    
      // Allow delete if the user is logged in and owns the project
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
  }
}
